#!/bin/bash

PkgHome="https://github.com/mltframework/mlt"

BuildSteps=("${BuildForPython[@]}")
[[ $BuildStep ]] && pkg_set_python "$BuildStep"

ConfigureOpts+=(
    #Slackware
    -DMOD_QT=ON
    -DMOD_QT6=ON
    -DMOD_JACKRACK=OFF
    -DMOD_RUBBERBAND=OFF
    -DMOD_GLXANIMATE=ON
    -DMOD_GLXANIMATE_QT6=ON

    -DSWIG_PYTHON=ON
)

pkg_pre_configure() {
    local f1=$OrigSrcDir/CMakeLists.txt
    # find_package(Python3 REQUIRED COMPONENTS Interpreter Development)
    # ->
    # find_package(Python3 "3.12...3.12.13" REQUIRED COMPONENTS Interpreter Development)
    pkg_create_orig "$f1"
    local s1='(find_package\(Python3).* (REQUIRED.*)'
    local s2='\1 "'"$PythonV12...$PythonV123"'" \2'
    sed -i -re "s,$s1,$s2," "$f1"

    # -libpostproc (ffmpeg-7.1)
    local f1=$OrigSrcDir/cmake/FindFFmpeg.cmake
    if pkg_create_orig "$f1"; then
        # find_component(POSTPROCESS libpostproc    postproc    libpostproc/postprocess.h)
        sed -i -re 's,^( *)(find_component\(POSTPROCESS .*),\1#\2,' "$f1"
    fi
}

pkg_post_install() {
    pkg_python_compileall "$LibDir2/python$PythonV12"
}
