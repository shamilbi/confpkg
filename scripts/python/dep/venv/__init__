#!/bin/bash

# compile $PythonVenvDir/ then copy to /usr

unset -v BuildSteps # pkg_python_install (BuildForPython)
unset -v pkg_configure pkg_make
unset -v PythonInstallLibs PythonInstallLibs0 PythonNoBuildIsolation
PythonVenvSystem=1

# Slackware
# Allow build to use CMake 4.x:
export CMAKE_POLICY_VERSION_MINIMUM=3.5

pkg_install() {
    pkg_python_install
}

pkg_distclean() {
    if [[ -d $PythonVenvDir ]]; then
        rm -rf "$PythonVenvDir" || return 1
    fi
}
