pkg_python_post_install() {
    local dir=$(find "$PythonVenvDir"/lib -type d -name site-packages -print -quit)
    if [[ -d $dir ]]; then
        rm -rf "$dir"/{docs,tests}
        rm -f "$dir"/*.rst
    fi
}
